# ─── Email (SMTP) ────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your SMTP credentials.
# The contact form and newsletter will log to console until these are set.
#
# Option A — Gmail (use an App Password, not your account password)
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=your-address@gmail.com
#   SMTP_PASS=your-app-password
#
# Option B — Custom SMTP (cPanel / hosting provider)
#   SMTP_HOST=mail.yourdomain.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=info@dhanalakshmiagroproducts.com
#   SMTP_PASS=your-email-password

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
